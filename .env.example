# Replicate API token (server-only, never exposed to the browser). Needed at step 6.
REPLICATE_API_TOKEN=

# Where canvas.json, uploads/ and generated/ live. Must be a persistent volume in prod.
DATA_DIR=./data

# Basic auth for the whole site (public domain + paid generation).
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# Optional: disable basic auth locally (any non-"false" value enables it).
BASIC_AUTH_ENABLED=false
